# ── Logging ───────────────────────────────────────────────────────────────────
WRITE_LOG_TO_DISK = false
LOGGING_LEVEL     = INFO
DIR_LOGS          = /var/log

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED     = true
TELEGRAM_BOT_KEY     = YOUR_BOT_KEY_HERE
TELEGRAM_BOT_CHAT_ID = YOUR_CHAT_ID_HERE

# ── Alert thresholds ──────────────────────────────────────────────────────────
CPU_USAGE_ALERT    = 90      # alert if CPU usage exceeds this %
CPU_TEMP_ALERT     = 80      # alert if CPU temp exceeds this °C
MEMORY_FREE_ALERT  = 10      # alert if free memory drops below this %
DISK_USAGE_ALERT   = 85      # alert if disk usage exceeds this %
DISK_FREE_GB_ALERT = 1.5     # alert if free disk drops below this GB

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_THROTTLE_CHECK = true   # Raspberry Pi only — disable on non-Pi hosts
